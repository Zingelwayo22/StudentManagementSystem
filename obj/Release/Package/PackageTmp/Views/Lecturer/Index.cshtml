@model IEnumerable<StudentManagementSystem.Models.Lecturer>

@{
    ViewBag.Title = "Lecturers";
}

<h2>Manage Lecturers</h2>

<p>
    @Html.ActionLink("Create New Lecturer", "Create", null, new { @class = "btn btn-primary" })
</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered table-striped">
    <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.LecturerId }, new { @class = "btn btn-warning btn-sm" })

                @Html.Raw(" ")

                @Html.ActionLink("Delete", "Delete", new { id = item.LecturerId }, new { @class = "btn btn-danger btn-sm" })
            </td>
        </tr>
    }
    </table>
