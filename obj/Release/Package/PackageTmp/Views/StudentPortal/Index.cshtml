@model IEnumerable<StudentManagementSystem.Models.Enrollment>

<h2>Student Dashboard</h2>

<hr />

<h3>Welcome @ViewBag.StudentName</h3>

<br />

<div class="row">

    <div class="col-md-3">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4> Modules Enrolled</h4>
            </div>

            <div class="panel-body">
                <h6>@ViewBag.ModuleCount</h6>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="panel panel-success">
            <div class="panel-heading">
                <h4>Marks Captured</h4>
            </div>

            <div class="panel-body">
                <h6>@ViewBag.MarkCount</h6>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="panel panel-warning">
            <div class="panel-heading">
               <h4>Average Score</h4>
            </div>

            <div class="panel-body">
                <h6>@ViewBag.AverageScore %</h6>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="panel panel-info">
            <div class="panel-heading">
               <h4>Academic Status</h4>
            </div>

            <div class="panel-body">
                <h6>@ViewBag.Status</h6>
            </div>
        </div>
    </div>

</div>

<hr />

<h3>My Modules</h3>

<table class="table table-bordered">

    <tr>
        <th>Module</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Module.ModuleName</td>
        </tr>
    }

</table>

<br />

<a href="@Url.Action("Results", "StudentPortal")"
   class="btn btn-success">
    View My Results
</a>
