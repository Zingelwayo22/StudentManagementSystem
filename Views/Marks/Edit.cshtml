@model StudentManagementSystem.Models.Mark

<h2>Edit Mark</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(m => m.MarkId)

    <div class="form-group">
        <label>Student</label>
        @Html.DisplayFor(m => m.Student.FirstName)
    </div>

    <div class="form-group">
        <label>Module</label>
        @Html.DisplayFor(m => m.Module.ModuleName)
    </div>

    <div class="form-group">
        <label>Score</label>
        @Html.TextBoxFor(m => m.Score, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-success">
        Save Changes
    </button>
}