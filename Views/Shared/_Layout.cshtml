<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Student Management System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" />
</head>

<body>

    <!-- NAVBAR -->
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">

            <div class="navbar-header">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    SMS System
                </a>
            </div>

            <ul class="nav navbar-nav">

                @if (User.IsInRole("Admin"))
                {
                    <li>@Html.ActionLink("Admin Dashboard", "Index", "Admin")</li>
                    <li>@Html.ActionLink("Students", "Index", "Student")</li>
                    <li>@Html.ActionLink("Lecturers", "Index", "Lecturer")</li>
                    <li>@Html.ActionLink("Modules", "Index", "Module")</li>
                }

                @if (User.IsInRole("Lecturer"))
                {
                    <li>@Html.ActionLink("Dashboard", "Index", "LecturerPortal")</li>
                    <li>@Html.ActionLink("Marks", "Index", "Marks")</li>
                }

                @if (User.IsInRole("Student"))
                {
                    <li>@Html.ActionLink("Dashboard", "Index", "StudentPortal")</li>
                    <li>@Html.ActionLink("My Results", "Results", "StudentPortal")</li>
                }

            </ul>

            <!-- LOGIN / LOGOUT -->
            <ul class="nav navbar-nav navbar-right">

                @if (Request.IsAuthenticated)
                {
                    using (Html.BeginForm("LogOff", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <li>
                            <button type="submit" class="btn btn-link navbar-btn">
                                Logout
                            </button>
                        </li>
                    }
                }
                else
                {
                    <li>@Html.ActionLink("Login", "Login", "Account")</li>
                }

            </ul>

        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container body-content" style="margin-top:70px;">

        @RenderBody()

        <hr />

        <footer>
            <p>&copy; 2026 - Student Management System</p>
        </footer>

    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>